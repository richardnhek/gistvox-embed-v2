{
  "functions": {
    "api/p/[id].js": {
      "maxDuration": 10
    },
    "api/og/[id].js": {
      "maxDuration": 20,
      "memory": 1024,
      "includeFiles": "Inter-*.ttf"
    },
    "api/test-og.js": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/p/:postId",
      "destination": "https://gistvox.com/post/:postId",
      "statusCode": 301
    },
    {
      "source": "/g/:groupId",
      "destination": "https://gistvox.com/group/:groupId",
      "statusCode": 301
    },
    {
      "source": "/series/:seriesId",
      "destination": "https://gistvox.com",
      "statusCode": 302
    },
    {
      "source": "/",
      "destination": "https://gistvox.com",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/api/favicon"
    },
    {
      "source": "/og/:id.png",
      "destination": "/api/og/:id"
    },
    {
      "source": "/embed/:id",
      "destination": "/api/embed/:id"
    },
    {
      "source": "/test-og",
      "destination": "/api/test-og"
    }
  ]
}
